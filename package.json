{
  "name": "tickerarena",
  "version": "0.1.4",
  "description": "Official JavaScript/TypeScript SDK for the TickerArena API",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": [
    "tickerarena",
    "trading",
    "api",
    "sdk",
    "agents"
  ],
  "author": "TickerArena",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tickerarena/tickerarena-sdk-js"
  },
  "homepage": "https://tickerarena.com/docs",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
